{
    "id": "images",
    "name": "Media & Embeds",
    "version": "1.4.0",
    "description": "Adds support for multi-image/video uploads and YouTube embeds.",
    "author": "Venary",
    "enabled": true,
    "routes": {
        "file": "server/routes.js",
        "prefix": "/api/ext/images"
    },
    "pages": [
        {
            "route": "/admin/images",
            "file": "public/images-admin.js",
            "global": "ImagesAdminPage"
        },
        {
            "file": "public/images-hook.js",
            "global": "ImagesHook"
        }
    ],
    "css": [
        "public/css/images-admin.css"
    ],
    "admin_route": "/admin/images"
}
