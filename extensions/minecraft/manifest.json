{
    "id": "minecraft",
    "name": "Minecraft",
    "version": "2.0.3",
    "description": "Full Minecraft integration — server list, pinging, downtime detection, stats leaderboards, account linking, and 3D skin viewer.",
    "author": "Venary",
    "enabled": true,
    "nav": [
        {
            "label": "Minecraft",
            "icon": "grid",
            "position": 2,
            "dropdown": true,
            "children": [
                {
                    "label": "Servers",
                    "route": "/servers",
                    "icon": "server"
                },
                {
                    "label": "Leaderboard",
                    "route": "/mc-leaderboard",
                    "icon": "users"
                },
                {
                    "label": "Link Account",
                    "route": "/mc-link",
                    "icon": "settings"
                }
            ]
        }
    ],
    "routes": {
        "prefix": "/api/ext/minecraft",
        "file": "server/routes.js"
    },
    "admin_route": "/minecraft-admin",
    "pages": [
        {
            "route": "/servers",
            "file": "public/pages/minecraft.js",
            "global": "MinecraftPage"
        },
        {
            "route": "/mc-leaderboard",
            "file": "public/pages/minecraft.js",
            "global": "MinecraftPage"
        },
        {
            "route": "/mc-link",
            "file": "public/pages/minecraft.js",
            "global": "MinecraftPage"
        },
        {
            "route": "/minecraft-admin",
            "file": "public/pages/minecraft-admin.js",
            "global": "MinecraftAdminPage"
        }
    ],
    "css": [
        "public/css/minecraft.css"
    ],
    "data": [
        "mc_servers",
        "linked_accounts",
        "player_stats",
        "mc_players",
        "uptime_history",
        "link_codes"
    ]
}